# Daemon
# The port the local kurumid HTTP server listens on
KURUMI_DAEMON_PORT=47392
# The host the daemon binds to
KURUMI_DAEMON_HOST=127.0.0.1
# Log level for the daemon (debug | info | warn | error)
KURUMI_LOG_LEVEL=info          
# Directory where daemon and process supervisor logs are stored
KURUMI_LOG_DIR=~/.config/kurumi/logs

# Debug / developer options
# Set to true to enable additional debug output/features
KURUMI_DEBUG=false
# Set to true to use a temporary DB or mock backends for testing
KURUMI_TEST_MODE=false         

# Ollama
# The host where the local Ollama instance is running
OLLAMA_HOST=127.0.0.1
# The port where Ollama is listening
OLLAMA_PORT=11434

# AirLLM
# The host where the local AirLLM Python server is running
AIRLLM_HOST=127.0.0.1
# The port the AirLLM Python server uses for its FastAPI endpoints
AIRLLM_PORT=8765

# NVIDIA (cloud, optional)
# API key for NVIDIA NIM cloud inference (Requires internet connectivity)
NVIDIA_API_KEY=

# Database
# Absolute or home-relative path to the Kurumi SQLite database file
KURUMI_DB_PATH=~/.config/kurumi/kurumi.db
