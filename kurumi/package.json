    "@radix-ui/react-tooltip": "^1.0.7",
    "@radix-ui/react-slider": "^1.1.2",
    "@radix-ui/react-select": "^2.0.0",
    "@dnd-kit/core": "^6.1.0",
    "overlayscrollbars-react": "^0.5.6",
    "date-fns": "^3.6.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "vite": "^5.2.0",
    "vite-plugin-electron": "^0.28.0",
