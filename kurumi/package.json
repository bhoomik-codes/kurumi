    "@types/react-dom": "^18.3.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/d3": "^7.4.0",
    "@types/katex": "^0.16.0",
    "@types/uuid": "^9.0.8",
    "@types/papaparse": "^5.3.14",
    "@types/node": "^20.12.0"
